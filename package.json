{
  "name": "scorecard",
  "version": "1.0.1",
  "description": "Personal scorecard, checklist, and timelog tracker",
  "author": "meme2025west-droid",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && node src/index.js",
    "desktop": "npm run build && electron electron/main.cjs",
    "desktop:dev": "electron electron/main.cjs",
    "desktop:rebuild": "npm run desktop:pack",
    "desktop:pack": "npm run build && electron-builder --win nsis",
    "desktop:pack-dir": "npm run build && electron-builder --win --dir"
  },
  "build": {
    "appId": "com.meme2025westdroid.scorecard",
    "productName": "Scorecard",
    "asar": true,
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server"
      },
      {
        "from": "server/node_modules",
        "to": "server/node_modules"
      },
      {
        "from": "client/dist",
        "to": "client/dist"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  }
}
